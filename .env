# ===== App =====
APP_NAME=DARU
APP_ENV=development
DEBUG=true

# ===== Database (PostgreSQL) =====
DATABASE_URL=postgresql+asyncpg://postgres:362608@192.168.219.101:3626/daru

# ===== Redis =====
REDIS_URL=redis://192.168.219.101:6379/0

# ===== JWT =====
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14

# ===== OAuth (소셜 로그인) =====
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/kakao/callback

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:8000/api/v1/auth/naver/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ===== LLM / Embedding =====
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ===== 외부 데이터 API =====
NAVER_NEWS_API_CLIENT_ID=
NAVER_NEWS_API_CLIENT_SECRET=
STOCK_PRICE_API_KEY=
MAP_DIRECTIONS_API_KEY=
WEATHER_API_KEY=

# ===== 게스트(비로그인) 설정 =====
GUEST_SESSION_TTL_HOURS=24
GUEST_SESSION_HEADER_NAME=X-Guest-Session-Id

# ===== RAG 파라미터 =====
NEWS_CLUSTER_SIMILARITY_THRESHOLD=0.85
