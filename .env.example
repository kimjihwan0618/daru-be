# ===== App =====
APP_NAME=DARU
APP_ENV=development
DEBUG=true

# ===== Database =====
# 현재: SQLite (개발용, 구조 검증 단계)
DATABASE_URL=sqlite+aiosqlite:///./daru.db

# PostgreSQL 전환 시 (docker-compose의 db 서비스 기준 예시) - 주석 해제 후 사용
# DATABASE_URL=postgresql+asyncpg://daru_user:daru_pass@localhost:5432/daru

# ===== Redis (Celery / 캐시, 추후 구현) =====
REDIS_URL=redis://localhost:6379/0

# ===== JWT =====
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14

# ===== OAuth (소셜 로그인) =====
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/kakao/callback

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:8000/api/v1/auth/naver/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ===== LLM / Embedding (추후 구현) =====
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ===== 외부 데이터 API (추후 구현) =====
NAVER_NEWS_API_CLIENT_ID=
NAVER_NEWS_API_CLIENT_SECRET=
STOCK_PRICE_API_KEY=
MAP_DIRECTIONS_API_KEY=
WEATHER_API_KEY=

# ===== 게스트(비로그인) 설정 =====
GUEST_SESSION_TTL_HOURS=24
GUEST_SESSION_HEADER_NAME=X-Guest-Session-Id

# ===== RAG 파라미터 =====
NEWS_CLUSTER_SIMILARITY_THRESHOLD=0.85
